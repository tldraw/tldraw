{
	"$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/fallow.schema.json",
	"entry": [
		"apps/docs/app/**/*.{ts,tsx}",
		"apps/dotcom/client/src/main.tsx",
		"apps/examples/src/index.tsx",
		"apps/mcp-app/src/worker.ts",
		"apps/mcp-app/src/widget/mcp-app.tsx",
		"apps/vscode/editor/src/index.tsx",
		"apps/vscode/extension/src/extension.ts",
		"internal/scripts/**/*.{js,mjs,ts,tsx}",
		"packages/create-tldraw/src/main.ts",
		"templates/agent/client/main.tsx",
		"templates/agent/worker/worker.ts",
		"templates/branching-chat/client/main.tsx",
		"templates/branching-chat/worker/worker.ts",
		"templates/image-pipeline/worker/worker.ts",
		"templates/simple-server-example/src/client/main.tsx",
		"templates/socketio-server-example/src/client/main.tsx",
		"templates/sync-cloudflare/client/main.tsx",
		"templates/sync-cloudflare/worker/worker.ts"
	],
	"ignorePatterns": [
		".github/**",
		".fallow/**",
		"**/.next/**",
		"**/.tsbuild/**",
		"**/*.css",
		"**/dist/**",
		"apps/docs/api/**",
		"apps/docs/content/gen/**",
		"apps/dotcom/client/index.html",
		"apps/dotcom/zero-cache/.schema.js",
		"apps/examples/www/**"
	],
	"dynamicallyLoaded": [
		"apps/dotcom/client/public/**",
		"apps/docs/content/**/*.{md,mdx}",
		"apps/examples/src/examples/**/*.{css,ts,tsx}",
		"apps/examples/src/examples/**/README.md",
		"skills/*/scripts/**/*.{js,mjs,ts,tsx}"
	],
	"ignoreExports": [
		{
			"file": "**/*.module.css",
			"exports": ["*"]
		},
		{
			"file": "apps/docs/app/**/*.{ts,tsx}",
			"exports": [
				"default",
				"dynamic",
				"generateMetadata",
				"generateStaticParams",
				"metadata",
				"revalidate",
				"viewport"
			]
		},
		{
			"file": "apps/dotcom/client/src/{pages,tla/pages,tla/providers}/**/*.{ts,tsx}",
			"exports": ["action", "Component", "ErrorBoundary", "HydrateFallback", "loader"]
		},
		{
			"file": "apps/examples/src/examples/**/*.{ts,tsx}",
			"exports": ["*"]
		},
		{
			"file": "apps/examples/src/misc/end-to-end.tsx",
			"exports": ["TLGlobalShapePropsMap"]
		},
		{
			"file": "templates/**/*.{ts,tsx}",
			"exports": ["*"]
		}
	],
	"publicPackages": ["@tldraw/*", "create-tldraw", "tldraw"],
	"rules": {
		"unused-class-members": "off"
	}
}
