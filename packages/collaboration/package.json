	"devDependencies": {
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"react": "^19.2.1",
		"react-dom": "^19.2.1"
	},
	"peerDependencies": {
		"react": "^18.2.0 || ^19.2.1",
		"react-dom": "^18.2.0 || ^19.2.1"
