{
	"name": "@tldraw/website",
	"description": "The tldraw marketing website.",
	"version": "0.0.0",
	"private": true,
	"author": {
		"name": "tldraw Inc.",
		"email": "hello@tldraw.com"
	},
	"homepage": "https://tldraw.dev",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/tldraw/tldraw"
	},
	"bugs": {
		"url": "https://github.com/tldraw/tldraw/issues"
	},
	"scripts": {
		"dev": "yarn refresh-content && concurrently \"next dev --port=3002\" \"tsx scripts/watcher.ts\" --kill-others",
		"next-dev": "next dev --port=3002",
		"refresh-content": "yarn run -T tsx --tsconfig ./tsconfig.content.json ./scripts/refresh-content.ts",
		"build": "yarn refresh-content && next build",
		"start": "next start",
		"lint": "yarn run -T tsx ../../internal/scripts/lint.ts",
		"screenshots": "yarn run -T tsx ../../.claude/skills/iterate-website-page/scripts/generate-screenshots.ts",
		"compare": "yarn run -T tsx ../../.claude/skills/iterate-website-page/scripts/compare-screenshots.ts"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"geist": "^1.3.1",
		"github-slugger": "^2.0.0",
		"gray-matter": "^4.0.3",
		"jsdom": "^28.0.0",
		"lucide-react": "^0.563.0",
		"next": "^16.1.6",
		"next-themes": "^0.4.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-is": "^19.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.1",
		"shiki": "^3.22.0",
		"sqlite": "^5.1.1",
		"sqlite3": "^5.1.7",
		"tailwind-merge": "^2.6.0",
		"tldraw": "npm:tldraw@next",
		"unified": "^11.0.5"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.1.18",
		"@tailwindcss/typography": "^0.5.16",
		"@types/jsdom": "^27.0.0",
		"@types/node": "^22.15.31",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/sqlite3": "^3.1.11",
		"@types/ws": "^8.18.1",
		"concurrently": "^9.1.2",
		"playwright": "^1.49.1",
		"postcss": "^8.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"sharp": "^0.33.5",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.8.3",
		"ws": "^8.18.0"
	}
}
