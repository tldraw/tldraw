{
	"name": "@tldraw/zero-cache",
	"description": "The production app for tldraw.",
	"version": "0.0.0",
	"private": true,
	"author": {
		"name": "tldraw GB Ltd.",
		"email": "hello@tldraw.com"
	},
	"browserslist": [
		"defaults"
	],
	"scripts": {
		"dev": "yarn run -T tsx ./dev.ts",
		"wait-for-dev-readiness": "yarn run -T tsx ./wait-for-dev-readiness.ts",
		"bundle-schema": "esbuild --bundle --platform=node --format=esm --outfile=./.schema.js ../../../packages/dotcom-shared/src/tlaSchema.ts",
		"bundle-schema:watch": "esbuild --bundle --watch --platform=node --format=esm --outfile=./.schema.js ../../../packages/dotcom-shared/src/tlaSchema.ts",
		"migrate": "yarn tsx ./migrate.ts",
		"lint": "yarn run -T tsx ../../../internal/scripts/lint.ts",
		"test": "yarn run -T vitest --passWithNoTests",
		"test-ci": "yarn run -T vitest run --passWithNoTests",
		"test-coverage": "yarn run -T vitest run --coverage --passWithNoTests"
	},
	"type": "module",
	"dependencies": {
		"@rocicorp/zero": "1.6.1",
		"kysely": "^0.28.12",
		"pg": "^8.13.1"
	},
	"devDependencies": {
		"concurrently": "^9.1.2",
		"dotenv": "^16.4.7",
		"esbuild": "^0.28.0",
		"lazyrepo": "0.0.0-alpha.27",
		"nodemon": "^3.1.9",
		"tsx": "^4.19.2"
	}
}
