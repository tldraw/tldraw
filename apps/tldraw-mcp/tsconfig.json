{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"jsx": "react-jsx",
		"sourceMap": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/widget/**", "node_modules", "dist"]
}
