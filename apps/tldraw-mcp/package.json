{
	"name": "tldraw-mcp",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "npm run build:widget && npm run build:server",
		"build:widget": "npx vite build && mv dist/index.html dist/mcp-app.html",
		"build:server": "npx tsc",
		"dev": "npx tsx src/main.ts",
		"start": "node dist/main.js",
		"start:stdio": "node dist/main.js --stdio"
	},
	"dependencies": {
		"@modelcontextprotocol/ext-apps": "^1.0.0",
		"@modelcontextprotocol/sdk": "^1.12.0",
		"express": "^5.1.0",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@types/express": "^5.0.0",
		"@types/node": "^20.0.0",
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"@vitejs/plugin-react": "^4.0.0",
		"react": "^18.3.0",
		"react-dom": "^18.3.0",
		"tldraw": "^4.3.1",
		"tsx": "^4.7.0",
		"typescript": "^5.5.0",
		"vite": "^6.0.0",
		"vite-plugin-singlefile": "^2.0.0"
	}
}
