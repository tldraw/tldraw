{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"jsx": "react-jsx",
		"sourceMap": true,
		"lib": ["ES2022", "DOM", "DOM.Iterable"]
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "main.ts", "vite.config.ts"],
	"exclude": ["node_modules", "dist"]
}
