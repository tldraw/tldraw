#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

yarn install --immutable
# Only run build-api for packages with staged changes
CHANGED_PACKAGES=$(git diff --cached --name-only | grep '^packages/' | cut -d/ -f2 | sort -u)
FILTER_ARGS=""
for pkg in $CHANGED_PACKAGES; do
	if [ -f "packages/$pkg/package.json" ] && grep -q '"build-api"' "packages/$pkg/package.json"; then
		FILTER_ARGS="$FILTER_ARGS --filter=packages/$pkg"
	fi
done
if [ -n "$FILTER_ARGS" ]; then
	npx lazy run build-api $FILTER_ARGS
	git add packages/*/api-report.api.md
fi
npx lazy run build-i18n
git add apps/*/locales/*.json
git add apps/*/locales-compiled/*.json
yarn lint-staged
